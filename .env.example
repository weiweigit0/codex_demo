# Company profile Agent: DeepSeek is the default provider.
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_CHAT_COMPLETIONS_URL=https://api.deepseek.com/chat/completions
LLM_TRANSPORT=requests

# Set LLM_TRANSPORT=curl only when an enterprise HTTPS proxy prevents requests from connecting.
# HTTPS_PROXY=https://proxy.example.com:8891
# HTTP_PROXY=https://proxy.example.com:8891

# Optional compatibility fallback. Switch LLM_PROVIDER=openai to activate it.
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
## Data platform: disabled by default to avoid background network work in local development.
DATA_SCHEDULED_REFRESH=false

# VideoBrief export: generate a dedicated Ed25519 key pair with
# scripts/generate_video_brief_keys.py. Do not reuse the DeepSeek key.
# VIDEO_BRIEF_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# VIDEO_BRIEF_SUBJECT_SALT=replace-with-a-long-random-secret
# VIDEO_BRIEF_KEY_ID=financial-mining-video-v1
# MEDIA_PRODUCTION_URL=http://localhost:8766

# Independent media-production service.
# MEDIA_BRIEF_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# MEDIA_ADMIN_TOKEN=replace-with-a-long-random-admin-token
# MEDIA_RENDER_MODE=demo
# MEDIA_ALLOWED_ORIGINS=http://localhost:8765
